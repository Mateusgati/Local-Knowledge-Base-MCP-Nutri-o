# Configuração da base de conhecimento de nutrição
# Copie este arquivo para .env e preencha

# Obrigatório - Chave da API Google AI Studio
# Obtenha em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=sua-api-key-aqui

# Modelo de embeddings (opcional)
EMBEDDING_MODEL=gemini-embedding-2

# Nome da collection no banco vetorial (opcional)
COLLECTION_NAME=biblioteca_nutricao

# Caminho do banco vetorial (opcional)
DB_PATH=vector_db_nutricao

# Pasta que contém exclusivamente os PDFs de nutrição
DOCS_DIR=documentos_nutricao
